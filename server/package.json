{
  "name": "commissioner-server",
  "version": "1.0.0",
  "main": "src/index.ts",
  "scripts": {
    "dev": "nodemon --exec ts-node src/index.ts",
    "build": "tsc && node -e \"const fs=require('fs');['prompts','templates','backgrounds'].forEach(d=>fs.cpSync(d,'dist/'+d,{recursive:true}))\"",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@aws-sdk/client-polly": "^3.1067.0",
    "@aws-sdk/client-s3": "^3.1064.0",
    "@supabase/supabase-js": "^2.43.4",
    "@types/sharp": "^0.31.1",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^173.0.0",
    "sharp": "^0.35.1"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.7",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "nodemon": "^3.1.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
